{
  "module": "系统设置 - 夜间模式",
  "test_suites": [
    {
      "scene": "夜间模式基础功能",
      "cases": [
        {
          "id": "TC-01",
          "title": "开启夜间模式 - 主题切换为深色",
          "preconditions": [
            "手机处于系统设置页面",
            "当前系统主题为浅色模式",
            "\"自动亮度\"功能处于关闭状态"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""}
          ],
          "expected": [
            "系统主题立即变为深色",
            "开关状态显示为\"已开启\""
          ]
        },
        {
          "id": "TC-02",
          "title": "关闭夜间模式 - 主题恢复为浅色",
          "preconditions": [
            "手机处于系统设置页面",
            "当前系统主题为深色模式（夜间模式已开启）"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""}
          ],
          "expected": [
            "系统主题恢复为浅色",
            "开关状态显示为\"已关闭\""
          ]
        }
      ]
    },
    {
      "scene": "夜间模式与自动亮度交互",
      "cases": [
        {
          "id": "TC-03",
          "title": "开启夜间模式时自动亮度已开启 - 弹出提示",
          "preconditions": [
            "手机处于系统设置页面",
            "\"自动亮度\"功能处于开启状态",
            "当前系统主题为浅色模式"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""}
          ],
          "expected": [
            "弹出提示框显示文本 \"建议关闭自动亮度以获得更好体验\"",
            "系统主题变为深色"
          ]
        },
        {
          "id": "TC-04",
          "title": "自动亮度关闭时开启夜间模式 - 无提示直接切换",
          "preconditions": [
            "手机处于系统设置页面",
            "\"自动亮度\"功能处于关闭状态",
            "当前系统主题为浅色模式"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""}
          ],
          "expected": [
            "无弹窗提示",
            "系统主题立即变为深色"
          ]
        },
        {
          "id": "TC-05",
          "title": "关闭夜间模式时自动亮度状态不影响操作",
          "preconditions": [
            "手机处于系统设置页面",
            "\"自动亮度\"功能处于开启状态",
            "夜间模式已开启（深色主题）"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "提示仅在开启时触发"}
          ],
          "expected": [
            "无弹窗提示",
            "系统主题恢复为浅色"
          ]
        }
      ]
    },
    {
      "scene": "异常边界与交互体验 [经验补遗]",
      "cases": [
        {
          "id": "TC-06",
          "title": "连续快速点击开关 - 幂等性自检",
          "preconditions": [
            "手机处于系统设置页面",
            "当前系统主题为浅色模式"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "连续 3 次（快速）"}
          ],
          "expected": [
            "系统应处理防抖，避免产生重复请求或逻辑错乱",
            "最终主题状态一致"
          ]
        },
        {
          "id": "TC-07",
          "title": "主题切换视觉反馈验证",
          "preconditions": [
            "手机处于系统设置页面"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""},
            {"action": "断言", "object": "屏幕视觉变化", "memo": "观察切换过程"}
          ],
          "expected": [
            "主题切换过程流畅，无明显闪烁",
            "所有 UI 元素颜色适配深色/浅色主题"
          ]
        },
        {
          "id": "TC-08",
          "title": "中断处理后状态一致性",
          "preconditions": [
            "手机处于系统设置页面",
            "夜间模式已开启（深色主题）"
          ],
          "steps": [
            {"action": "后台", "object": "切换应用至后台", "memo": ""},
            {"action": "等待", "object": "5 秒", "memo": ""},
            {"action": "前台", "object": "返回应用", "memo": ""}
          ],
          "expected": [
            "夜间模式状态保持一致（仍为开启状态）",
            "系统主题仍为深色"
          ]
        },
        {
          "id": "TC-09",
          "title": "极端文本显示 - 提示框内容完整性",
          "preconditions": [
            "手机处于系统设置页面",
            "\"自动亮度\"功能处于开启状态",
            "系统语言设置为多国语言（如德语、日语等）"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": ""}
          ],
          "expected": [
            "提示文本完整显示，无重叠或生硬截断",
            "UI 支持自动换行或省略号显示"
          ]
        }
      ]
    },
    {
      "scene": "闭环路径验证 [经验补遗]",
      "cases": [
        {
          "id": "TC-10",
          "title": "开启 - 关闭完整流程",
          "preconditions": [
            "手机处于系统设置页面",
            "当前系统主题为浅色模式"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "开启"},
            {"action": "断言", "object": "主题变为深色", "memo": ""},
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "关闭"},
            {"action": "断言", "object": "主题恢复浅色", "memo": ""}
          ],
          "expected": [
            "开启和关闭操作均可正常执行",
            "主题切换可逆，无残留状态"
          ]
        },
        {
          "id": "TC-11",
          "title": "多次切换后状态正确",
          "preconditions": [
            "手机处于系统设置页面"
          ],
          "steps": [
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "开启"},
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "关闭"},
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "开启"},
            {"action": "点击", "object": "开关 \"夜间模式\"", "memo": "关闭"}
          ],
          "expected": [
            "每次切换后主题状态正确",
            "无状态累积或逻辑错误"
          ]
        }
      ]
    }
  ]
}
